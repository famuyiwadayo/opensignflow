datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output = "./generated"
}


enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum DocumentStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_SIGNED
  COMPLETED
  CANCELLED
}

enum DocumentFieldType {
  SIGNATURE
  INITIALS
  TEXT
  DATE
  CHECKBOX
}

enum RecipientStatus {
  PENDING
  SENT
  VIEWED
  SIGNED
  DECLINED
  EXPIRED
}

enum SigningRequestStatus {
  PENDING
  SENT
  VIEWED
  COMPLETED
  EXPIRED
  REVOKED
}

enum AuditActorType {
  USER
  RECIPIENT
  SYSTEM
  AI
  WEBHOOK
}

enum AuditEventType {
  DOCUMENT_CREATED
  DOCUMENT_UPLOADED
  DOCUMENT_UPDATED
  DOCUMENT_DELETED
  DOCUMENT_FIELD_CREATED
  DOCUMENT_FIELD_UPDATED
  DOCUMENT_FIELD_DELETED
  RECIPIENT_CREATED
  RECIPIENT_UPDATED
  RECIPIENT_DELETED
  DOCUMENT_SENT
  DOCUMENT_CANCELLED
  SIGNING_LINK_OPENED
  RECIPIENT_VIEWED
  RECIPIENT_SIGNED
  RECIPIENT_DECLINED
  DOCUMENT_COMPLETED
  FINAL_PDF_GENERATED
  AI_SUMMARY_GENERATED
  AI_FIELD_SUGGESTIONS_GENERATED
  AI_EMAIL_DRAFT_GENERATED
  SUBSCRIPTION_UPDATED
}

enum AiAnalysisType {
  DOCUMENT_SUMMARY
  FIELD_SUGGESTIONS
  EMAIL_DRAFT
  RISK_CHECK
}

enum ProcessingStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobType {
  PDF_TEXT_EXTRACTION
  PDF_FINALIZATION
  EMAIL_SEND_SIGNING_REQUEST
  AI_DOCUMENT_SUMMARY
  AI_FIELD_SUGGESTIONS
  AI_EMAIL_DRAFT
  BILLING_SYNC
}

enum PlanCode {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  INCOMPLETE
}

enum UsageMetric {
  DOCUMENT_CREATED
  DOCUMENT_SENT
  AI_ANALYSIS_RUN
  AI_INPUT_TOKENS
  AI_OUTPUT_TOKENS
  STORAGE_BYTES
}

model User {
  id              String    @id @db.VarChar(40)
  email           String    @unique @db.VarChar(320)
  normalizedEmail String    @unique @map("normalized_email") @db.VarChar(320)
  name            String?   @db.VarChar(120)
  passwordHash    String?   @map("password_hash")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  memberships      OrganizationMember[]
  sessions         UserSession[]
  createdDocuments Document[]           @relation("DocumentCreatedBy")
  createdAnalyses  AiAnalysis[]         @relation("AiAnalysisCreatedBy")
  auditEvents      AuditEvent[]         @relation("AuditActorUser")

  @@map("users")
}

model UserSession {
  id               String    @id @db.VarChar(40)
  userId           String    @map("user_id") @db.VarChar(40)
  refreshTokenHash String    @unique @map("refresh_token_hash")
  ipAddress        String?   @map("ip_address") @db.VarChar(80)
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  lastUsedAt       DateTime? @map("last_used_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model Organization {
  id          String   @id @db.VarChar(40)
  name        String   @db.VarChar(120)
  slug        String?  @unique @db.VarChar(80)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members       OrganizationMember[]
  documents     Document[]
  auditEvents   AuditEvent[]
  analyses      AiAnalysis[]
  jobs          JobRecord[]
  subscriptions Subscription[]
  usageRecords  UsageRecord[]

  @@map("organizations")
}

model OrganizationMember {
  id             String           @id @db.VarChar(40)
  organizationId String           @map("organization_id") @db.VarChar(40)
  userId         String           @map("user_id") @db.VarChar(40)
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Document {
  id                  String         @id @db.VarChar(40)
  organizationId      String         @map("organization_id") @db.VarChar(40)
  createdById         String         @map("created_by_id") @db.VarChar(40)
  title               String         @db.VarChar(200)
  status              DocumentStatus @default(DRAFT)
  originalFileName    String         @map("original_file_name") @db.VarChar(255)
  mimeType            String         @map("mime_type") @db.VarChar(120)
  fileSizeBytes       Int            @map("file_size_bytes")
  originalStorageKey  String         @map("original_storage_key")
  completedStorageKey String?        @map("completed_storage_key")
  pageCount           Int?           @map("page_count")
  finalSha256         String?        @map("final_sha256") @db.VarChar(64)
  sentAt              DateTime?      @map("sent_at")
  completedAt         DateTime?      @map("completed_at")
  deletedAt           DateTime?      @map("deleted_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("DocumentCreatedBy", fields: [createdById], references: [id])

  fields          DocumentField[]
  recipients      Recipient[]
  signingRequests SigningRequest[]
  submissions     SigningSubmission[]
  fieldValues     DocumentFieldValue[]
  auditEvents     AuditEvent[]
  analyses        AiAnalysis[]

  @@index([organizationId, status, createdAt])
  @@index([createdById])
  @@map("documents")
}

model Recipient {
  id           String          @id @db.VarChar(40)
  documentId   String          @map("document_id") @db.VarChar(40)
  name         String          @db.VarChar(120)
  email        String          @db.VarChar(320)
  status       RecipientStatus @default(PENDING)
  signingOrder Int             @default(1) @map("signing_order")
  viewedAt     DateTime?       @map("viewed_at")
  signedAt     DateTime?       @map("signed_at")
  declinedAt   DateTime?       @map("declined_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  document        Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fields          DocumentField[]
  signingRequests SigningRequest[]
  submissions     SigningSubmission[]
  fieldValues     DocumentFieldValue[]
  auditEvents     AuditEvent[]

  @@unique([documentId, email])
  @@index([documentId, status])
  @@map("recipients")
}

model DocumentField {
  id          String            @id @db.VarChar(40)
  documentId  String            @map("document_id") @db.VarChar(40)
  recipientId String?           @map("recipient_id") @db.VarChar(40)
  type        DocumentFieldType
  pageNumber  Int               @map("page_number")
  x           Decimal           @db.Decimal(8, 6)
  y           Decimal           @db.Decimal(8, 6)
  width       Decimal           @db.Decimal(8, 6)
  height      Decimal           @db.Decimal(8, 6)
  required    Boolean           @default(true)
  label       String?           @db.VarChar(120)
  placeholder String?           @db.VarChar(120)
  defaultValue String?          @map("default_value")
  validation  Json?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  document  Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recipient Recipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  values    DocumentFieldValue[]

  @@index([documentId, pageNumber])
  @@index([recipientId])
  @@map("document_fields")
}

model SigningRequest {
  id          String               @id @db.VarChar(40)
  documentId  String               @map("document_id") @db.VarChar(40)
  recipientId String               @map("recipient_id") @db.VarChar(40)
  tokenHash   String               @unique @map("token_hash")
  status      SigningRequestStatus @default(PENDING)
  expiresAt   DateTime             @map("expires_at")
  sentAt      DateTime?            @map("sent_at")
  viewedAt    DateTime?            @map("viewed_at")
  completedAt DateTime?            @map("completed_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  document    Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recipient   Recipient  @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  submissions SigningSubmission[]

  @@index([documentId])
  @@index([recipientId])
  @@map("signing_requests")
}

model SigningSubmission {
  id               String   @id @db.VarChar(40)
  documentId       String   @map("document_id") @db.VarChar(40)
  recipientId      String   @map("recipient_id") @db.VarChar(40)
  signingRequestId String   @map("signing_request_id") @db.VarChar(40)
  ipAddress        String?  @map("ip_address") @db.VarChar(80)
  userAgent        String?  @map("user_agent")
  submittedAt      DateTime @default(now()) @map("submitted_at")
  createdAt        DateTime @default(now()) @map("created_at")

  document       Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recipient      Recipient      @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  signingRequest SigningRequest @relation(fields: [signingRequestId], references: [id], onDelete: Cascade)
  fieldValues    DocumentFieldValue[]

  @@index([documentId])
  @@index([recipientId])
  @@index([signingRequestId])
  @@map("signing_submissions")
}

model DocumentFieldValue {
  id                  String   @id @db.VarChar(40)
  documentId          String   @map("document_id") @db.VarChar(40)
  fieldId             String   @map("field_id") @db.VarChar(40)
  recipientId         String   @map("recipient_id") @db.VarChar(40)
  signingSubmissionId String   @map("signing_submission_id") @db.VarChar(40)
  value               Json
  createdAt           DateTime @default(now()) @map("created_at")

  document          Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  field             DocumentField     @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  recipient         Recipient         @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  signingSubmission SigningSubmission @relation(fields: [signingSubmissionId], references: [id], onDelete: Cascade)

  @@unique([signingSubmissionId, fieldId])
  @@index([documentId])
  @@map("document_field_values")
}

model AuditEvent {
  id             String         @id @db.VarChar(40)
  organizationId String         @map("organization_id") @db.VarChar(40)
  documentId     String?        @map("document_id") @db.VarChar(40)
  actorUserId    String?        @map("actor_user_id") @db.VarChar(40)
  recipientId    String?        @map("recipient_id") @db.VarChar(40)
  eventType      AuditEventType @map("event_type")
  actorType      AuditActorType @map("actor_type")
  actorEmail     String?        @map("actor_email") @db.VarChar(320)
  ipAddress      String?        @map("ip_address") @db.VarChar(80)
  userAgent      String?        @map("user_agent")
  metadata       Json?
  createdAt      DateTime       @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document     Document?    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actorUser    User?        @relation("AuditActorUser", fields: [actorUserId], references: [id])
  recipient    Recipient?   @relation(fields: [recipientId], references: [id])

  @@index([organizationId, createdAt])
  @@index([documentId, createdAt])
  @@index([eventType])
  @@map("audit_events")
}

model AiAnalysis {
  id             String           @id @db.VarChar(40)
  organizationId String           @map("organization_id") @db.VarChar(40)
  documentId     String           @map("document_id") @db.VarChar(40)
  createdById    String?          @map("created_by_id") @db.VarChar(40)
  type           AiAnalysisType
  status         ProcessingStatus @default(QUEUED)
  provider       String?          @db.VarChar(80)
  model          String?          @db.VarChar(120)
  promptVersion  String?          @map("prompt_version") @db.VarChar(40)
  inputTokens    Int?             @map("input_tokens")
  outputTokens   Int?             @map("output_tokens")
  result         Json?
  errorMessage   String?          @map("error_message")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document     Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("AiAnalysisCreatedBy", fields: [createdById], references: [id])

  @@index([organizationId, type, createdAt])
  @@index([documentId, type])
  @@map("ai_analyses")
}

model JobRecord {
  id             String           @id @db.VarChar(40)
  organizationId String?          @map("organization_id") @db.VarChar(40)
  type           JobType
  status         ProcessingStatus @default(QUEUED)
  resourceType   String?          @map("resource_type") @db.VarChar(80)
  resourceId     String?          @map("resource_id") @db.VarChar(40)
  attempts       Int              @default(0)
  errorMessage   String?          @map("error_message")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  completedAt    DateTime?        @map("completed_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, createdAt])
  @@index([resourceType, resourceId])
  @@map("job_records")
}

model Subscription {
  id                     String             @id @db.VarChar(40)
  organizationId          String             @map("organization_id") @db.VarChar(40)
  planCode                PlanCode           @default(FREE) @map("plan_code")
  status                  SubscriptionStatus @default(ACTIVE)
  provider                String?            @db.VarChar(80)
  providerCustomerId      String?            @map("provider_customer_id") @db.VarChar(160)
  providerSubscriptionId  String?            @unique @map("provider_subscription_id") @db.VarChar(160)
  currentPeriodStart      DateTime?          @map("current_period_start")
  currentPeriodEnd        DateTime?          @map("current_period_end")
  cancelAtPeriodEnd       Boolean            @default(false) @map("cancel_at_period_end")
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  usageRecords UsageRecord[]

  @@index([organizationId, status])
  @@map("subscriptions")
}

model UsageRecord {
  id             String      @id @db.VarChar(40)
  organizationId String      @map("organization_id") @db.VarChar(40)
  subscriptionId String?     @map("subscription_id") @db.VarChar(40)
  metric         UsageMetric
  quantity       Int
  periodStart    DateTime    @map("period_start")
  periodEnd      DateTime    @map("period_end")
  metadata       Json?
  createdAt      DateTime    @default(now()) @map("created_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([organizationId, metric, periodStart, periodEnd])
  @@map("usage_records")
}

model IdempotencyRecord {
  id             String   @id @db.VarChar(40)
  organizationId String?  @map("organization_id") @db.VarChar(40)
  userId         String?  @map("user_id") @db.VarChar(40)
  key            String   @db.VarChar(200)
  method         String   @db.VarChar(12)
  path           String   @db.VarChar(500)
  requestHash    String   @map("request_hash") @db.VarChar(64)
  responseStatus Int?     @map("response_status")
  responseBody   Json?    @map("response_body")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([userId, method, path, key])
  @@index([organizationId])
  @@index([expiresAt])
  @@map("idempotency_records")
}
